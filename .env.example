# Copy this file to ".env" and fill in your values, then restart the server.

# Your Anthropic API key. Get one from https://console.anthropic.com/
# WITHOUT this, the AI assistant runs in "demo mode" (everything else still works).
ANTHROPIC_API_KEY=

# Optional: which Claude model the assistant uses (default: claude-opus-4-8)
# MODEL=claude-opus-4-8

# Optional: port to run on (default: 4000)
# PORT=4000

# Set to 1 ONLY when running behind a trusted reverse proxy (e.g. Render) so the
# real client IP is read from X-Forwarded-For for rate limiting. Leave UNSET for
# direct exposure (the Docker image) so a spoofed header can't bypass limits.
# TRUST_PROXY=1

# ── HubSpot lead capture (optional) ───────────────────────────────────────────
# The /api/lead endpoint creates a HubSpot contact from the contact form.
# WITHOUT a token it runs in demo mode (logs the enquiry, doesn't send it).
# Create a Private App in HubSpot (Settings → Integrations → Private Apps) with the
# scopes  crm.objects.contacts.write  and  crm.objects.contacts.read , then paste
# its access token here. The token is read at startup and never logged or sent
# anywhere except HubSpot's API.
HUBSPOT_PRIVATE_APP_TOKEN=

# Label stored with each enquiry so you can see where it came from.
# LEAD_SOURCE=365 Techies website

# If the public website posts the form from a different origin than this server,
# list the allowed origins (comma-separated) so the browser will permit it, e.g.
# LEAD_ALLOWED_ORIGINS=https://www.365techies.co.uk,https://365techies.co.uk

# ── Off-Grid app (Victron VRM) ────────────────────────────────────────────────
# The "Off-Grid" app shows live Victron data. WITHOUT these it runs on demo data.
# Create an Access token in VRM (Portal -> avatar -> Preferences -> Integrations
# -> Access tokens) and find your site/installation id in the VRM URL.
# The token stays server-side and is never sent to the browser.
# VRM_API_TOKEN=
# VRM_SITE_ID=
# VRM_SITE_NAME=          # optional label shown in the app
